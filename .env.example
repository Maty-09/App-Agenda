# Copia este archivo a .env y completa las variables con tus datos reales

# Base de datos y autenticación (obligatorias)
DATABASE_URL=***REMOVED***
JWT_SECRET_KEY=***REMOVED***

# API de IA
INCEPTION_API_KEY=

# Cuenta de envío (Gmail, Outlook, etc.)
EMAIL_SENDER=agendamiento.localdemo@gmail.com

# Token o contraseña de aplicación para la cuenta de envío
EMAIL_PASSWORD=***REMOVED***
# o
# EMAIL_TOKEN=tu_token_o_contraseña_app_aqui

# Correo que recibe notificaciones internas
EMAIL_ADMIN=matiasduranm09@gmail.com

# URL pública de tu aplicación (útil para los links de confirmación)
BASE_URL=http://localhost:8000

# WhatsApp (Twilio). Se usa para todos los tenants que tengan whatsapp=true.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Protege GET /api/v1/cron/notificaciones. El scheduler externo envía este valor como Bearer token.
CRON_SECRET=usa_un_valor_largo_y_aleatorio

# Logo para los correos
LOGO_URL=https://static.wixstatic.com/media/63336e_1df8bf9a9c1542f2ba703877a908b01d~mv2.webp
